<?php

use Drupal\Core\Entity\EntityTypeInterface;
use Drupal\Core\Entity\EntityInterface;

/**
 * Implements hook_mail().
 */
function appointment_mail($key, &$message, $params) {
  switch ($key) {
    case 'booking_confirmation':
      /** @var \Drupal\appointment\Entity\AppointmentEntity $appointment */
      $appointment = $params['appointment'];
      $reference = $params['reference'] ?? $appointment->id();

      $date = $appointment->get('appointment_date')->value;

      $message['subject'] = t('Confirmation de votre rendez-vous (@ref)', ['@ref' => $reference]);
      $message['body'][] = t('Bonjour @name,', ['@name' => $appointment->get('customer_name')->value]);
      $message['body'][] = '';
      $message['body'][] = t('Votre rendez-vous a bien été enregistré avec la référence @ref.', ['@ref' => $reference]);
      $message['body'][] = t('Date et heure (UTC) : @date', ['@date' => $date]);
      $message['body'][] = '';
      $message['body'][] = t('Merci.');
      break;

    case 'booking_modified':
      /** @var \Drupal\appointment\Entity\AppointmentEntity $appointment */
      $appointment = $params['appointment'];
      $reference = $params['reference'] ?? $appointment->id();
      $date = $appointment->get('appointment_date')->value;

      $message['subject'] = t('Modification de votre rendez-vous (@ref)', ['@ref' => $reference]);
      $message['body'][] = t('Bonjour @name,', ['@name' => $appointment->get('customer_name')->value]);
      $message['body'][] = '';
      $message['body'][] = t('Votre rendez-vous a été modifié. Référence : @ref.', ['@ref' => $reference]);
      $message['body'][] = t('Nouvelle date et heure (UTC) : @date', ['@date' => $date]);
      $message['body'][] = '';
      $message['body'][] = t('Merci.');
      break;

    case 'booking_cancelled':
      /** @var \Drupal\appointment\Entity\AppointmentEntity $appointment */
      $appointment = $params['appointment'];
      $reference = $params['reference'] ?? $appointment->id();
      $date = $appointment->get('appointment_date')->value;

      $message['subject'] = t('Annulation de votre rendez-vous (@ref)', ['@ref' => $reference]);
      $message['body'][] = t('Bonjour @name,', ['@name' => $appointment->get('customer_name')->value]);
      $message['body'][] = '';
      $message['body'][] = t('Votre rendez-vous a été annulé. Référence : @ref.', ['@ref' => $reference]);
      $message['body'][] = t('Créneau initial (UTC) : @date', ['@date' => $date]);
      $message['body'][] = '';
      $message['body'][] = t('Merci.');
      break;
  }
}

/**
 * Implements hook_theme().
 */
function appointment_theme($existing, $type, $theme, $path): array {
  return [
    'appointment_booking_form' => [
      'render element' => 'form',
      'template' => 'appointment-booking-form',
      'path' => $path . '/templates',
    ],
    'appointment_modify_form' => [
      'render element' => 'form',
      'template' => 'appointment-modify-form',
      'path' => $path . '/templates',
    ],
  ];
}

/**
 * Implements hook_entity_base_field_info_alter().
 * Use this to add extra validation constraints.
 */
function appointment_entity_base_field_info_alter(&$fields, EntityTypeInterface $entity_type) {
  if ($entity_type->id() === 'appointment') {
    // Example: add phone format constraint
    if (isset($fields['customer_phone'])) {
      // Apply the regex to the actual scalar value, not the FieldItemList.
      $fields['customer_phone']->addPropertyConstraints('value', [
        'Regex' => [
          'pattern' => '/^(06|07)\d{8}$/',
          'message' => t('Phone must be a valid Moroccan number (06/07XXXXXXXX).'),
        ],
      ]);
    }
  }
}

/**
 * Implements hook_entity_presave().
 */
function appointment_entity_presave(EntityInterface $entity): void {
  if ($entity->getEntityTypeId() !== 'appointment') {
    return;
  }

  // Ensure a unique human reference exists.
  if ($entity->hasField('reference') && (string) $entity->get('reference')->value === '') {
    $date = (new \DateTime('now', new \DateTimeZone('UTC')))->format('Ymd');
    $rand = substr(bin2hex(random_bytes(6)), 0, 12);
    $entity->set('reference', 'AP-' . $date . '-' . strtoupper($rand));
  }

  // Ensure duration is set from settings if empty.
  if ($entity->hasField('duration_minutes') && (int) $entity->get('duration_minutes')->value <= 0) {
    $slot = (int) (\Drupal::config('appointment.settings')->get('slot_minutes') ?: 60);
    $entity->set('duration_minutes', max(5, $slot));
  }
}
