{#
/**
 * @file
 * Appointment modify form layout (booking-style).
 *
 * Available variables:
 * - form: The form render array.
 */
#}

{{ attach_library('appointment/booking_form') }}

<div class="appointment-booking appointment-booking--modify" data-step="4">
  <div class="appointment-booking__card">
    <h2 class="appointment-booking__title">{{ 'Modifier un rendez-vous'|t }}</h2>
    <p class="appointment-booking__subtitle">
      {{ 'Choisissez un nouveau créneau'|t }}
    </p>

    <div class="appointment-booking__steps">
      {{ form.steps_wrapper }}
    </div>

    <div class="appointment-booking__actions">
      {{ form.actions }}
    </div>
  </div>
</div>

{{ form|without('current_step', 'steps_wrapper', 'actions') }}

