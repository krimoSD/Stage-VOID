{{ attach_library('custom_dynamic_fields/ca_header_tailwind') }}

{% set section_title = extra_fields.group_header.section_title ?? 'INSIGHTS' %}
{% set section_subtitle = extra_fields.group_header.section_subtitle ?? '' %}
{% set button_label = extra_fields.group_footer.button_label ?? 'VOIR TOUS LES INSIGHTS' %}
{% set button_url = extra_fields.group_footer.button_url ?? '#' %}

<section style="width: 100vw; margin-left: calc(50% - 50vw); margin-right: calc(50% - 50vw); background-color: #fcfcfc; padding-top: 5rem; padding-bottom: 0;">
  <div class="mx-auto max-w-[1280px] px-4 sm:px-6 lg:px-8">
    
    <!-- Header -->
    <div class="mb-16 flex flex-col items-center text-center">
      <div class="flex items-center justify-center gap-4">
        <span class="block h-[2px] w-12 bg-[#2b84e8]"></span>
        {% if section_title is not empty %}
          <h2 class="m-0 text-3xl font-extrabold tracking-widest text-[#0a0a0a] uppercase">{{ section_title }}</h2>
        {% endif %}
      </div>
      {% if section_subtitle is not empty %}
        <p class="mt-6 text-lg font-normal text-[#4b5563]">{{ section_subtitle }}</p>
      {% endif %}
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      
      {% for item in content %}
        {% set image_uri = (item.image.0 is defined) ? get_image(item.image.0) : '' %}
        {% set slide_image = image_uri is not empty ? file_url(image_uri) : 'https://via.placeholder.com/600x400/eeeeee/cccccc' %}
        
        <article class="flex h-full flex-col overflow-hidden rounded-xl bg-white shadow-[0_4px_20px_-4px_rgba(0,0,0,0.05)] transition-shadow duration-300 hover:shadow-[0_8px_30px_-4px_rgba(0,0,0,0.1)]">
          <div class="h-56 w-full shrink-0 overflow-hidden bg-gray-100 p-2 pb-0">
            <img src="{{ slide_image }}" alt="{{ item.title }}" class="h-full w-full rounded-t-lg object-cover" loading="lazy">
          </div>
          <div class="flex flex-1 flex-col p-8">
            <div class="mb-5 flex items-center gap-4">
              {% if item.category_name is not empty %}
                <span class="rounded-full bg-[#0a1936] px-3 py-1 text-[11px] font-bold uppercase tracking-wider text-white">{{ item.category_name }}</span>
              {% endif %}
              {% if item.date is not empty %}
                <time class="text-sm font-medium text-[#9ca3af]">{{ item.date }}</time>
              {% endif %}
            </div>
            {% if item.title is not empty %}
              <h3 class="mb-8 text-[22px] font-bold leading-[1.3] text-[#0a0a0a]">{{ item.title }}</h3>
            {% endif %}
            {% if item.link_url is not empty %}
              <div class="mt-auto">
                <a href="{{ item.link_url }}" class="inline-block border-b-2 border-[#2b84e8] pb-1 text-sm font-bold uppercase tracking-wider text-[#2b84e8] transition-colors hover:border-[#0b5fb3] hover:text-[#0b5fb3]">LIRE PLUS</a>
              </div>
            {% endif %}
          </div>
        </article>
      {% endfor %}

    </div>

    <!-- Footer Button -->
    {% if button_url is not empty and button_url != '#' %}
      <div class="mt-16 flex justify-center pb-8">
        <a href="{{ button_url }}" class="inline-flex items-center justify-center rounded-lg border border-[#2b84e8] bg-white px-8 py-3.5 text-[13px] font-bold uppercase tracking-wider text-[#2b84e8] transition-all duration-200 hover:bg-[#2b84e8] hover:text-white">
          {{ button_label }}
        </a>
      </div>
    {% elseif button_label is not empty %}
      <div class="mt-16 flex justify-center pb-8">
        <a href="#" class="inline-flex items-center justify-center rounded-lg border border-[#2b84e8] bg-white px-8 py-3.5 text-[13px] font-bold uppercase tracking-wider text-[#2b84e8] transition-all duration-200 hover:bg-[#2b84e8] hover:text-white">
          {{ button_label }}
        </a>
      </div>
    {% endif %}

  </div>
</section>
