{#
/**
 * @file
 * Booking form layout.
 *
 * Available variables:
 * - form: The form render array.
 */
#}

{{ attach_library('appointment/booking_form') }}

{% set step = form.current_step['#value']|default(1) %}
{% set step_titles = {
  1: 'Choisissez une agence',
  2: 'Choisissez un type de rendez-vous',
  3: 'Choisissez un conseiller',
  4: 'Choisissez votre créneau',
  5: 'Renseignez vos informations',
  6: 'Confirmez votre rendez-vous'
} %}

<div class="appointment-booking appointment-booking--step-{{ step }}" data-step="{{ step }}">
  <div class="appointment-booking__card">
    <h2 class="appointment-booking__title">{{ 'Prendre un rendez-vous'|t }}</h2>
    <p class="appointment-booking__subtitle">
      {{ step_titles[step]|default('Suivez les étapes.'|t) }}
    </p>

    <div class="appointment-booking__stepper" aria-hidden="true">
      {% for i, label in {
        1: 'Agence',
        2: 'Type',
        3: 'Conseiller',
        4: 'Créneau',
        5: 'Infos',
        6: 'Confirmation'
      } %}
        <div class="appointment-booking__stepper-item {{ step >= i ? 'is-done' : '' }} {{ step == i ? 'is-current' : '' }}">
          <div class="appointment-booking__stepper-dot">{{ i }}</div>
          <div class="appointment-booking__stepper-label">{{ label|t }}</div>
        </div>
      {% endfor %}
    </div>

    <div id="booking-steps-wrapper" class="appointment-booking__steps">
      {{ form.steps_wrapper }}
    </div>

    <div class="appointment-booking__actions">
      {{ form.actions }}
    </div>
  </div>
</div>

{# Render any remaining form elements (hidden fields, tokens, etc.). #}
{{ form|without('current_step', 'steps_wrapper', 'actions') }}