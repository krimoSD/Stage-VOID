<section style="width:100%;background:#eef3fb;padding:4rem 1.5rem;font-family:sans-serif;">
  <div style="max-width:1100px;margin:0 auto;">

    <!-- Header -->
    <div style="margin-bottom:3rem;">
      <div style="display:flex;align-items:flex-start;gap:1rem;margin-bottom:1rem;">
        <span style="display:block;width:2.5rem;height:3px;background:#2b84e8;flex-shrink:0;margin-top:0.55rem;"></span>
        <h2 style="margin:0;font-size:1.6rem;font-weight:800;text-transform:uppercase;color:#0a1936;line-height:1.25;letter-spacing:-0.01em;">
          DES SERVICES INNOVANTS POUR UN QUOTIDIEN SIMPLIFIÉ.
        </h2>
      </div>
      <p style="margin:0 0 0 3.5rem;font-size:0.9rem;color:#4b5563;line-height:1.7;max-width:520px;">
        Capital Azur accompagne l'ensemble de sa clientèle dans leurs projets à toutes les étapes de leurs vie.
      </p>
    </div>

    <!-- Carousel row -->
    <div style="position:relative;display:flex;align-items:center;gap:0.75rem;">

      <!-- Prev arrow -->
      <button style="background:none;border:none;cursor:pointer;color:#a0b4cc;flex-shrink:0;padding:0;" aria-label="Précédent">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none">
          <path d="M15 6 9 12l6 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <!-- Cards -->
      <div style="display:flex;gap:1rem;flex:1;overflow:hidden;">

        {% set services = [
          { label: 'Comptes & Cartes' },
          { label: 'Epargne' },
          { label: 'Crédit' },
          { label: 'Assurance' }
        ] %}

        {% for svc in services %}
          <div style="flex:0 0 calc(25% - 0.75rem);background:#fff;border-radius:1rem;padding:2rem 1.5rem;display:flex;flex-direction:column;align-items:center;gap:1.25rem;text-align:center;box-shadow:{% if loop.index == 3 %}0 8px 30px -6px rgba(43,132,232,0.25);border:2px solid #2b84e8;transform:translateY(-4px){% else %}0 2px 8px rgba(0,0,0,0.05){% endif %};">
            <!-- placeholder icon -->
            <svg width="72" height="72" viewBox="0 0 64 64" fill="none" style="color:#2b84e8;">
              <rect x="8" y="20" width="48" height="32" rx="4" stroke="currentColor" stroke-width="2.5"/>
              <path d="M8 28h48" stroke="currentColor" stroke-width="2"/>
              <circle cx="20" cy="36" r="4" stroke="currentColor" stroke-width="2"/>
              <path d="M32 36h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            <span style="font-size:0.9rem;font-weight:700;color:#0a1936;">{{ svc.label }}</span>
          </div>
        {% endfor %}

      </div>

      <!-- Next arrow -->
      <button style="background:none;border:none;cursor:pointer;color:#2b84e8;flex-shrink:0;padding:0;" aria-label="Suivant">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none">
          <path d="m9 6 6 6-6 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

    </div>
  </div>
</section>
