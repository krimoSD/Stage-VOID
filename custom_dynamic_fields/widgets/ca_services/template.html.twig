{{ attach_library('custom_dynamic_fields/ca_header_tailwind') }}
{{ attach_library('custom_dynamic_fields/ca_services_behavior') }}

{% set section_title = extra_fields.group_header.section_title ?? 'DES SERVICES INNOVANTS POUR UN QUOTIDIEN SIMPLIFIÉ.' %}
{% set section_description = extra_fields.group_header.section_description ?? '' %}
{% set show_arrows = (extra_fields.group_config.arrows is defined and extra_fields.group_config.arrows > 0) %}
{% set autoplay = (extra_fields.group_config.autoLoop is not empty and extra_fields.group_config.autoLoop > 0) ? 1 : 0 %}
{% set autoplay_speed = (extra_fields.group_config.loopSpeed is not empty) ? extra_fields.group_config.loopSpeed : 4000 %}
{% set visible_items = (extra_fields.group_config.visible_items is not empty) ? extra_fields.group_config.visible_items : 4 %}

<section class="w-full bg-[#eef3fb] py-16 lg:py-24">
  <div class="mx-auto max-w-[1280px] px-6 lg:px-8">

    {# ── Header ── #}
    <div class="mb-12">
      <div class="flex items-start gap-4 mb-6">
        <span class="mt-2 block h-[3px] w-10 shrink-0 bg-[#2b84e8]"></span>
        {% if section_title is not empty %}
          <h2 class="m-0 max-w-[640px] text-2xl font-extrabold uppercase leading-tight tracking-tight text-[#0a1936] md:text-3xl">{{ section_title }}</h2>
        {% endif %}
      </div>
      {% if section_description is not empty %}
        <p class="ml-[3.5rem] max-w-[540px] text-[15px] leading-relaxed text-[#4b5563]">{{ section_description }}</p>
      {% endif %}
    </div>

    {# ── Carousel wrapper ── #}
    <div class="relative"
         data-autoplay="{{ autoplay }}"
         data-autoplay-speed="{{ autoplay_speed }}"
         data-visible="{{ visible_items }}">

      {# Prev arrow #}
      {% if show_arrows %}
        <button type="button"
                class="js-ca-services-prev absolute -left-6 top-1/2 z-20 -translate-y-1/2 text-[#a0b4cc] transition-colors hover:text-[#2b84e8] focus:outline-none"
                aria-label="Précédent">
          <svg class="h-10 w-10" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M15 6 9 12l6 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      {% endif %}

      {# Viewport #}
      <div class="js-ca-services-viewport overflow-hidden">
        <div class="js-ca-services-track flex transition-transform duration-500 ease-in-out will-change-transform">
          {% for item in content %}
            {% set icon_uri = (item.icon.0 is defined) ? get_image(item.icon.0) : '' %}
            {% set icon_src = icon_uri is not empty ? file_url(icon_uri) : '' %}
            {% set link = item.link_url is not empty ? item.link_url : '#' %}
            <div class="js-ca-services-slide shrink-0 px-3"
                 style="width: calc(100% / {{ visible_items }});"
                 data-index="{{ loop.index0 }}">
              <a href="{{ link }}"
                 class="js-ca-services-card group flex flex-col items-center gap-5 rounded-2xl bg-white p-8 text-center shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_30px_-6px_rgba(43,132,232,0.2)] {% if loop.first %}ring-2 ring-[#2b84e8] shadow-[0_8px_30px_-6px_rgba(43,132,232,0.25)] -translate-y-1{% endif %}">
                <div class="flex h-20 w-20 items-center justify-center">
                  {% if icon_src is not empty %}
                    <img src="{{ icon_src }}" alt="{{ item.label }}" class="h-full w-full object-contain" loading="lazy">
                  {% else %}
                    {# Fallback placeholder icon #}
                    <svg class="h-14 w-14 text-[#2b84e8]" viewBox="0 0 64 64" fill="none" aria-hidden="true">
                      <rect x="8" y="20" width="48" height="32" rx="4" stroke="currentColor" stroke-width="2.5"/>
                      <path d="M8 28h48" stroke="currentColor" stroke-width="2"/>
                      <circle cx="20" cy="36" r="4" stroke="currentColor" stroke-width="2"/>
                    </svg>
                  {% endif %}
                </div>
                {% if item.label is not empty %}
                  <span class="text-[15px] font-bold text-[#0a1936] transition-colors group-hover:text-[#2b84e8]">{{ item.label }}</span>
                {% endif %}
              </a>
            </div>
          {% endfor %}
        </div>
      </div>

      {# Next arrow #}
      {% if show_arrows %}
        <button type="button"
                class="js-ca-services-next absolute -right-6 top-1/2 z-20 -translate-y-1/2 text-[#2b84e8] transition-colors hover:text-[#0b5fb3] focus:outline-none"
                aria-label="Suivant">
          <svg class="h-10 w-10" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="m9 6 6 6-6 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      {% endif %}

    </div>{# end relative wrapper #}
  </div>
</section>
