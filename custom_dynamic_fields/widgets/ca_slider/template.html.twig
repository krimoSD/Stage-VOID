{{ attach_library('custom_dynamic_fields/ca_header_tailwind') }}
{{ attach_library('custom_dynamic_fields/ca_slider_behavior') }}

{% set show_arrows = (extra_fields.group_gonfig.arrows is defined and extra_fields.group_gonfig.arrows > 0) %}
{% set show_dots = (extra_fields.group_gonfig.dots is defined and extra_fields.group_gonfig.dots > 0) %}
{% set loop_enabled = (extra_fields.group_gonfig.loop is not empty and extra_fields.group_gonfig.loop > 0) ? 1 : 1 %}
{% set autoplay_enabled = (extra_fields.group_gonfig.autoLoop is not empty and extra_fields.group_gonfig.autoLoop > 0) ? 1 : 1 %}
{% set autoplay_speed = (extra_fields.group_gonfig.loopSpeed is not empty) ? extra_fields.group_gonfig.loopSpeed : 5000 %}

<section class="relative left-1/2 right-1/2 w-screen max-w-none -translate-x-1/2 overflow-hidden pb-0">
  <div class="js-ca-slider relative w-full"
       data-loop="{{ loop_enabled }}"
       data-autoplay="{{ autoplay_enabled }}"
       data-autoplay-speed="{{ autoplay_speed }}">
    <div class="relative w-full overflow-hidden" style="aspect-ratio:16/7;">
      {% for item in content %}
        {% set image_uri = (item.image.0 is defined) ? get_image(item.image.0) : '' %}
        {% set slide_image = image_uri is not empty ? file_url(image_uri) : '' %}
        <article class="js-ca-slide absolute inset-0 w-full h-full bg-white transition-opacity duration-700 ease-in-out {% if loop.first %}z-10 opacity-100 pointer-events-auto{% else %}z-0 opacity-0 pointer-events-none{% endif %}">
          {% if slide_image is not empty %}
            <img src="{{ slide_image }}" alt="" class="absolute inset-0 h-full w-full object-contain" loading="lazy">
          {% endif %}
          <div class="relative z-10 flex h-full items-center px-8 sm:px-12">
            <div class="w-full max-w-[590px] rounded-lg bg-white/95 p-8 shadow-sm overflow-hidden" style="max-height:80%;">
              <div class="mb-4 flex items-center gap-4">
                <span class="block h-[3px] w-10 bg-[#2b84e8]"></span>
                <h2 class="m-0 text-[52px] font-extrabold leading-[1.05] tracking-[-0.02em] text-[#0a0a0a]">{{ item.title }}</h2>
              </div>
              {% if item.description is not empty %}
                <p class="m-0 text-[38px] font-normal leading-[1.2] text-[#1f2937] overflow-hidden" style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;">{{ item.description }}</p>
              {% endif %}
            </div>
          </div>
        </article>
      {% endfor %}
    </div>

    {% if show_arrows %}
      <div class="absolute inset-y-0 left-0 right-0 z-20 flex items-center justify-between px-4">
        <button type="button" class="js-ca-slider-prev text-[#6aa7e8] hover:text-[#2b84e8]" aria-label="Previous slide">
          <svg class="h-12 w-12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M15 6 9 12l6 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button type="button" class="js-ca-slider-next text-[#2b84e8] hover:text-[#0b5fb3]" aria-label="Next slide">
          <svg class="h-12 w-12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="m9 6 6 6-6 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    {% endif %}

    {% if show_dots and content|length > 1 %}
      <div class="absolute bottom-5 left-1/2 z-20 flex -translate-x-1/2 items-center gap-2">
        {% for item in content %}
          <button type="button"
                  class="js-ca-slider-dot h-2.5 w-2.5 rounded-full {% if loop.first %}bg-white/90{% else %}bg-white/40{% endif %}"
                  aria-label="Go to slide {{ loop.index }}"
                  aria-current="{% if loop.first %}true{% else %}false{% endif %}"></button>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>
